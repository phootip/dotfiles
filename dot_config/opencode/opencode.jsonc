{
  "$schema": "https://opencode.ai/config.json",
  "keybinds": {
    "editor_open": "f2",
    "messages_half_page_up": "ctrl+u",
    "messages_half_page_down": "ctrl+d",
  },
  "plugin": [
    "@zhafron/opencode-kiro-auth"
  ],
  "provider": {
    "kiro": {
      "models": {
        "claude-sonnet-4-5": {
          "name": "Claude Sonnet 4.5",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        },
        "claude-sonnet-4-5-thinking": {
